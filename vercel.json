{
  "crons": [
    {
      "path": "/api/send-daily-email",
      "schedule": "0 10 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/enviar-emails-funnel",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "X-Cron-Secret, Content-Type"
      }
    }
  ]
} 